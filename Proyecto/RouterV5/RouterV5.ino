void registrar(String m) { 
  registroLog = "[" + String(millis()/1000) + "s] " + m + "<br>" + registroLog; 
  if(registroLog.length() > 600) registroLog = registroLog.substring(0, 500);
}

// ================= MOTOR DE SEGURIDAD LÓGICO =================
bool accesoAutorizado() {
  if (!servidor.authenticate(http_user, http_pass)) { 
    servidor.requestAuthentication(); 
    return false; 
  }
  return true;
}

// ================= RUTAS WEB =================
void handleRoot() {
  String html = String(html_publico);
  html.replace("%CSS%", String(css_estilos));
  html.replace("%ESTADO_INTERNET%", internetActivo ? "<span style='color:#0f0'>ENRUTANDO INTERNET</span>" : "<span style='color:#ff3300'>SOLO INTRANET LOCAL</span>");
  html.replace("%LOG%", registroLog);
  servidor.send(200, "text/html", html);
}

void handleAdmin() {
  if (!accesoAutorizado()) return; 
  String html = String(html_admin);
  html.replace("%CSS%", String(css_estilos));
  html.replace("%LOG%", registroLog);
  html.replace("%POTENCIA%", String(potenciaWifi));
  servidor.send(200, "text/html", html);
}

void handlePantalla() {
  if (!accesoAutorizado()) return; 
  modoPantalla = servidor.arg("m").toInt();
  registrar(modoPantalla == 0 ? "OLED: Modo Info Activo" : "OLED: Modo Logo Activo");
  servidor.sendHeader("Location", RUTA_SECRETA);
  servidor.send(303);
}

void handlePwr() {
  if (!accesoAutorizado()) return; 
  modoEnergia = servidor.arg("m").toInt();
  if(modoEnergia == 0) { 
    setCpuFrequencyMhz(80); Wire.begin(21, 22); registrar("PWR: Sigilo (80MHz)"); 
  } else { 
    setCpuFrequencyMhz(240); Wire.begin(21, 22); registrar("PWR: Maximo (240MHz)"); 
  }
  servidor.sendHeader("Location", RUTA_SECRETA);
  servidor.send(303);
}

void handlePotencia() {
  if (!accesoAutorizado()) return; 
  if (servidor.hasArg("v")) {
    potenciaWifi = servidor.arg("v").toInt();
    wifi_power_t setPwr = WIFI_POWER_19_5dBm;
    if (potenciaWifi <= 5) setPwr = WIFI_POWER_5dBm;
    else if (potenciaWifi <= 8) setPwr = WIFI_POWER_8_5dBm;
    else if (potenciaWifi <= 15) setPwr = WIFI_POWER_15dBm;
    WiFi.setTxPower(setPwr);
    registrar("NEXUS: TX a " + String(potenciaWifi) + " dBm");
  }
  servidor.sendHeader("Location", RUTA_SECRETA);
  servidor.send(303);
}

void handleConectarNAT() {
  if (!accesoAutorizado()) return;
  String ssid = servidor.arg("s");
  String pass = servidor.arg("p");
  
  // Mensaje previo para que el celular sepa que se va a desconectar por el salto de canal
  String html = "<html><body style='background:#000;color:#0f0;font-family:monospace;text-align:center;padding:50px;'>";
  html += "<h2>INICIANDO SALTO DE CANAL NAT</h2>";
  html += "<p>El modem se esta anclando a: <b>" + ssid + "</b></p>";
  html += "<p>Tu celular se desconectara del WiFi GAMA_Nexus unos segundos.</p>";
  html += "<p>Revisa la pantalla OLED. Si dice ONLINE, reconecta tu WiFi y recarga la pagina secreta.</p>";
  html += "<br><a href='" + String(RUTA_SECRETA) + "' style='color:#00ffcc;'>Volver al Panel</a>";
  html += "</body></html>";
  servidor.send(200, "text/html", html);
  
  delay(1000); 
  
  registrar("NAT: Anclando a " + ssid + "...");
  WiFi.begin(ssid.c_str(), pass.c_str());
  
  int intentos = 0;
  while(WiFi.status() != WL_CONNECTED && intentos < 15) {
    delay(500);
    intentos++;
  }
  
  if(WiFi.status() == WL_CONNECTED) {
    ip_napt_enable((uint32_t)WiFi.softAPIP(), 1);
    internetActivo = true;
    registrar("NAT: CONECTADO Y ENRUTANDO INTERNET");
  } else {
    internetActivo = false;
    registrar("NAT ERROR: Fallo al conectar. Verifique credenciales.");
  }
}

// ================= SETUP =================
void setup() {
  esp_task_wdt_config_t wdt_config = { .timeout_ms = TIEMPO_WDT * 1000, .idle_core_mask = (1 << portNUM_PROCESSORS) - 1, .trigger_panic = true };
  esp_task_wdt_init(&wdt_config); esp_task_wdt_add(NULL); 

  pinMode(LED_SISTEMA, OUTPUT);

  Wire.begin(21, 22); 
  disp1.begin(SSD1306_SWITCHCAPVCC, 0x3C);

  // MODO DUAL: Se conecta a una red (STA) y crea la suya propia (AP)
  WiFi.mode(WIFI_AP_STA);
  WiFi.setTxPower(WIFI_POWER_19_5dBm); 
  
  // Nombre de red y contraseña
  WiFi.softAP("GAMA_Nexus", "GAMA_2026_SEC", 1, 0, 4);

  // --- REGISTRO DE RUTAS WEB ---
  servidor.on("/", handleRoot);
  servidor.on(RUTA_SECRETA, handleAdmin); 
  servidor.on("/pantalla", handlePantalla); 
  servidor.on("/pwr", handlePwr);
  servidor.on("/set_potencia", handlePotencia);
  servidor.on("/conectar_nat", HTTP_POST, handleConectarNAT);
  
  // Falso error 404 para ocultar el sistema a intrusos
  servidor.onNotFound([]() {
    servidor.send(404, "text/plain", "ERROR 404: DIRECTORIO INEXISTENTE EN EL NUCLEO GAMA.");
  });

  // OTA (Actualización sin cables)
  servidor.on("/update", HTTP_POST, []() {
    if (!accesoAutorizado()) return;
    servidor.sendHeader("Connection", "close");
    servidor.send(200, "text/plain", (Update.hasError()) ? "FALLO DE ACTUALIZACION" : "EXITO! REINICIANDO SISTEMA...");
    delay(1000);
    ESP.restart();
  }, []() {
    if (!servidor.authenticate(http_user, http_pass)) return; 
    HTTPUpload& upload = servidor.upload();
    if (upload.status == UPLOAD_FILE_START) {
      if (!Update.begin(UPDATE_SIZE_UNKNOWN)) Update.printError(Serial);
    } else if (upload.status == UPLOAD_FILE_WRITE) {
      if (Update.write(upload.buf, upload.currentSize) != upload.currentSize) Update.printError(Serial);
    } else if (upload.status == UPLOAD_FILE_END) {
      if (Update.end(true)) registrar("OTA: Sistema Actualizado");
    }
  });

  servidor.begin();
}

void loop() {
  esp_task_wdt_reset();
  servidor.handleClient();        
  unsigned long t = millis();

  // Optimización OLED (Actualiza pantalla cada 250ms)
  if (t - tUltimaPantalla > 250) {
    tUltimaPantalla = t;
    disp1.clearDisplay();
    disp1.setTextColor(WHITE);
    
    // --- LÓGICA MANUAL DE PANTALLA ---
    if (modoPantalla == 0) {
      
      // MODO DATOS DE RED: Carrusel automático (Cambia cada 4 segundos)
      int carrusel = (t / 4000) % 3; 

      if (carrusel == 0) {
        // VISTA 1: Información Básica
        disp1.setCursor(0,0); disp1.print("GAMA NEXUS V5");
        disp1.drawFastHLine(0, 10, 128, WHITE);
        
        disp1.setCursor(0, 20); disp1.print("IP: "); disp1.print(WiFi.softAPIP());
        disp1.setCursor(0, 35); disp1.print("RED: GAMA_Nexus");
        disp1.setCursor(0, 50); disp1.print("TX PWR: "); disp1.print(potenciaWifi); disp1.print(" dBm");
      }
      else if (carrusel == 1) {
        // VISTA 2: Nodos Conectados (En grande)
        disp1.setCursor(0,0); disp1.print("GAMA NEXUS V5");
        disp1.drawFastHLine(0, 10, 128, WHITE);
        
        disp1.setCursor(0, 25); disp1.print("DISPOSITIVOS (NODOS):");
        disp1.setTextSize(2);
        disp1.setCursor(55, 40); disp1.print(WiFi.softAPgetStationNum());
        disp1.setTextSize(1); // Regresamos el tamaño a normal
      }
      else if (carrusel == 2) {
        // VISTA 3: Estado del Repetidor (NAT)
        disp1.setCursor(0,0); disp1.print("GAMA NEXUS V5");
        disp1.drawFastHLine(0, 10, 128, WHITE);
        
        disp1.setCursor(0, 20); disp1.print("MODO REPETIDOR:");
        if (internetActivo) {
          disp1.setCursor(0, 35); disp1.print("ESTADO: ONLINE");
          disp1.setCursor(0, 50); disp1.print("ENRUTANDO INTERNET");
        } else {
          disp1.setCursor(0, 35); disp1.print("ESTADO: OFFLINE");
          disp1.setCursor(0, 50); disp1.print("SOLO INTRANET");
        }
      }

    } else {
      
      // MODO LOGO FIJO (Salvapantallas manual)
      disp1.drawBitmap(0, 0, epd_bitmap_final_image__3_, 128, 64, WHITE);
      
    }
    
    disp1.display();
  }

  // Parpadeo del LED de estado
  if(modoEnergia == 1) digitalWrite(LED_SISTEMA, (t / 500) % 2);
  else digitalWrite(LED_SISTEMA, LOW);
}